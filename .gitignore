# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this is
# commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Web related

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/libs/
/android/app/src/main/assets/
/android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java

# Arch specific
/android/app/src/main/jniLibs/

# Android
# google-services.json is committed intentionally (Android key is restricted,
# ships in the APK, and CI needs it to build with the google-services plugin).
**/android/local.properties
**/android/key.properties
**/android/*.jks
**/android/*.keystore
**/android/.gradle

# iOS
**/ios/.generated/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Pods/
**/ios/.symlinks/

# Windows
**/windows/flutter/ephemeral/

# Linux
**/linux/flutter/ephemeral/

# MacOS
**/macos/Flutter/ephemeral/

# Environment variables
.env
.env.*
!.env.example

# Test
# Tests are version-controlled so CI's "Test" step actually runs them.
# Only local-only, sensitive, or scratch tests are ignored, by naming convention:
#   *_local_test.dart  — keep real credentials / private experiments out of the repo
test/**/*_local_test.dart

# Local-only planning notes (kept out of version control)
implementation_plan.md
todo.md

# Impeccable design skill — local tooling, do not commit
.claude/skills/impeccable/
.github/skills/impeccable/
.github/hooks/impeccable.json
.impeccable/

# Reverse-engineering artifacts (decompiled official app + APKs) — local only, do NOT commit
reverse-engineering/

# Android signing secrets — NEVER commit
**/android/key.properties
*.jks
*.keystore